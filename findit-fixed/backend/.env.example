# ─── Required ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/findit

# JWT_SECRET signs short-lived ACCESS tokens (15 min). Use 32+ random chars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── Strongly recommended (warnings shown if unset) ──────────
# Separate secret for refresh tokens. If unset we fall back to JWT_SECRET+":refresh".
JWT_REFRESH_SECRET=change-me-to-a-different-32-char-random-string

# 32+ char key used to encrypt 2FA secrets at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TWOFA_ENC_KEY=change-me-to-a-32-byte-hex-or-base64-key

# Token TTLs (Express + ms units accepted by jsonwebtoken)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── Admin bootstrap (DEV ONLY) ─────────────────────────────
# Set to "true" only when you need to use POST /api/auth/first-admin or /make-admin.
# In production, leave UNSET and grant the first admin role via the database directly.
ALLOW_ADMIN_BOOTSTRAP=false
ADMIN_SECRET=change-me-too

# ─── Server / proxy ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Used in password-reset email links
FRONTEND_URL=http://localhost:3000

# CORS allowlist — comma-separated. REQUIRED in production.
# CORS_ORIGIN=https://app.findit.example.com,https://www.findit.example.com

# ─── Email (leave blank to disable email features in dev) ────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM="FindIt <noreply@findit.local>"
